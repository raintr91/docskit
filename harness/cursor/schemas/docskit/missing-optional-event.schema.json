{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/raintr91/docskit/schemas/docskit/missing-optional-event.schema.json",
  "title": "Docskit missing optional accelerator event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "event",
    "package",
    "runId",
    "optional",
    "reason",
    "fallback",
    "metrics"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "event": { "const": "docskit.missing-optional" },
    "package": { "const": "@platform/docskit" },
    "runId": { "type": "string", "minLength": 1 },
    "optional": { "type": "string", "minLength": 1 },
    "reason": {
      "enum": ["not-configured", "unavailable", "invocation-failed"]
    },
    "fallback": {
      "enum": ["targeted-local-search", "model-analysis"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fileReads", "contextBytes"],
      "properties": {
        "fileReads": { "type": "integer", "minimum": 0 },
        "contextBytes": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
