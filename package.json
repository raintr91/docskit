{
  "name": "@platform/docskit",
  "version": "0.0.4",
  "description": "Local MCP: docs hub & spec engine — architecture and bundle IR",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "docskit": "./bin/docskit.mjs",
    "docskit-mcp": "./bin/docskit-mcp.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raintr91/docskit.git"
  },
  "homepage": "https://github.com/raintr91/docskit#readme",
  "bugs": {
    "url": "https://github.com/raintr91/docskit/issues"
  },
  "files": [
    "bin",
    "dist",
    "docs/INIT.md",
    "docs/INSTALL.md",
    "engines",
    "examples",
    "harness",
    "templates",
    "install.sh",
    "install.ps1",
    "mcp-package.json",
    "mcp.cursor.example.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "mcp": "node bin/docskit-mcp.mjs",
    "cli": "node bin/docskit.mjs",
    "dev": "tsx src/mcp/server.ts",
    "test": "npm run build && node --test test/*.test.mjs",
    "harness:sync": "node scripts/sync-harness-examples.mjs",
    "harness:check": "node scripts/sync-harness-examples.mjs --check"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "mcp",
    "arc42",
    "c4",
    "docs",
    "docskit",
    "bundle",
    "spec"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0"
  }
}