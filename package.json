{
  "name": "@platform/hubdocs",
  "version": "1.0.0",
  "description": "Local MCP: arc42/C4 docs hub — list IDs, deps, orphans, validate links, route chapter",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "hubdocs": "./bin/hubdocs.mjs",
    "hubdocs-mcp": "./bin/hubdocs-mcp.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raintr91/hubdocs.git"
  },
  "homepage": "https://github.com/raintr91/hubdocs#readme",
  "bugs": {
    "url": "https://github.com/raintr91/hubdocs/issues"
  },
  "files": [
    "bin",
    "dist",
    "docs/INIT.md",
    "docs/INSTALL.md",
    "examples",
    "harness",
    "install.sh",
    "install.ps1",
    "mcp-package.json",
    "mcp.cursor.example.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "mcp": "node bin/hubdocs-mcp.mjs",
    "cli": "node bin/hubdocs.mjs",
    "dev": "tsx src/mcp/server.ts",
    "test": "npm run build && node --test test/*.test.mjs",
    "harness:sync": "node scripts/sync-harness-examples.mjs",
    "harness:check": "node scripts/sync-harness-examples.mjs --check",
    "platform:workspace": "node scripts/platform-workspace-from-repos.mjs --group=mcp --out=platform-mcp.code-workspace"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "mcp",
    "arc42",
    "c4",
    "docs",
    "hubdocs"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0"
  }
}
